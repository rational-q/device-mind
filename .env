# ============================================================
# DeviceMind 环境变量配置
# 使用方式: docker-compose up -d 自动读取
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=devicemind

# ---- TimescaleDB (PostgreSQL) ----
POSTGRES_PASSWORD=root123
POSTGRES_DB=devicemind_ts

# ---- Redis ----
REDIS_PASSWORD=root123

# ---- Kafka ----
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092

# ---- Java 服务（docker-compose --profile all 时使用） ----
SPRING_PROFILES_ACTIVE=prod

# Core 服务数据源
MYSQL_URL=jdbc:mysql://mysql:3306/devicemind?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=${MYSQL_ROOT_PASSWORD}
TSDB_URL=jdbc:postgresql://timescaledb:5432/devicemind_ts
TSDB_USERNAME=postgres
TSDB_PASSWORD=${POSTGRES_PASSWORD}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_DEVICE_DATA=device-data

# 服务间调用
CORE_SERVICE_URL=http://core:8080
AGENT_SERVICE_URL=http://agent:8081
