<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.devicemind.core.persistence.mapper.timescale.DmDeviceDataMapper">

    <!-- 时序数据分页（时间范围筛选） -->
    <select id="selectDataPage" resultType="com.devicemind.core.model.vo.DeviceDataVO">
        SELECT EXTRACT(EPOCH FROM TIME) AS time,
               DEVICE_ID               AS deviceId,
               ATTR_NAME               AS attrName,
               VALUE                   AS value
        FROM device_data
        <where>
            <if test="deviceId != null and deviceId != ''">
                AND DEVICE_ID = #{deviceId}
            </if>
            <if test="attrName != null and attrName != ''">
                AND ATTR_NAME = #{attrName}
            </if>
            <if test="start != null">
                AND TIME &gt;= TO_TIMESTAMP(#{start})
            </if>
            <if test="end != null">
                AND TIME &lt;= TO_TIMESTAMP(#{end})
            </if>
        </where>
        ORDER BY TIME DESC
    </select>

</mapper>
