<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.devicemind.core.persistence.dao.timescale.DeviceDataDao">

    <select id="selectDataPage" resultType="com.devicemind.core.model.vo.DeviceDataVO">
        SELECT EXTRACT(EPOCH FROM TIME) AS time,
               DEVICE_ID               AS deviceId,
               ATTR_NAME               AS attrName,
               VALUE                   AS value,
               VALUE_TEXT              AS valueText
        FROM device_data
        <where>
            <if test="deviceId != null and deviceId != ''">
                AND DEVICE_ID = #{deviceId}
            </if>
            <if test="attrName != null and attrName != ''">
                AND ATTR_NAME = #{attrName}
            </if>
            <if test="start != null">
                AND TIME &gt;= TO_TIMESTAMP(#{start})
            </if>
            <if test="end != null">
                AND TIME &lt;= TO_TIMESTAMP(#{end})
            </if>
        </where>
        ORDER BY TIME DESC
    </select>

    <select id="selectLatestDataTimes" resultType="java.util.Map">
        SELECT DEVICE_ID AS "deviceId", MAX(TIME) AS "lastTime"
        FROM device_data
        WHERE DEVICE_ID IN
        <foreach collection="deviceIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
        GROUP BY DEVICE_ID
    </select>

</mapper>
